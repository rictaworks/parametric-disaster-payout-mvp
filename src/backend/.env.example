# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# reCAPTCHA
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# 管理画面ベーシック認証
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASSWORD=your_admin_password

# データベース（本番用PostgreSQL）
DATABASE_URL=******localhost:5432/parametric_disaster_payout_production

# 気象庁フィードURL
JMA_FEED_URL=https://www.data.jma.go.jp/developer/xml/feed/eqvol.xml

# Next.js→Rails間の内部認証シークレット（BFFサーバーサイドのみ使用）
INTERNAL_API_SECRET=change_me_to_a_long_random_secret

# フロントエンドURL（CORS設定用）
FRONTEND_URL=http://localhost:3000

# タイムゾーン
TZ=Asia/Tokyo

# 開発環境：認証スキップ（本番では絶対にtrue にしないこと）
# SKIP_AUTH=true

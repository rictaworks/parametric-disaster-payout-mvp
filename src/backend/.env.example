# Rails Master Key (for credentials decryption in production)
# RAILS_MASTER_KEY=your-production-master-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# reCAPTCHA
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Admin basic auth
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASSWORD=changeme

# Database (PostgreSQL for production; development uses SQLite)
DATABASE_URL=postgresql://DB_USER:DB_PASS@localhost:5432/parametric_disaster_payout

# JMA (Japan Meteorological Agency) feed
JMA_FEED_URL=https://www.data.jma.go.jp/developer/xml/feed/eqvol.xml
JMA_RAINFALL_FEED_URL=https://www.data.jma.go.jp/developer/xml/feed/other.xml

# Internal API secret (Next.js -> Rails internal auth)
INTERNAL_API_SECRET=change-this-to-a-random-secret

# Timezone
TZ=Asia/Tokyo

# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:3000

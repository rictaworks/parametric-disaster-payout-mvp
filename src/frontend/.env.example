# Next.js API URL (Points to Rails API)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Google OAuth Client ID (Frontend side)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# reCAPTCHA Site Key (Frontend side)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Internal API secret (Next.js -> Rails internal auth)
INTERNAL_API_SECRET=change-this-to-a-random-secret
